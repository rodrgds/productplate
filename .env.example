CONVEX_DEPLOYMENT=dev:your-project-123
PUBLIC_CONVEX_URL=https://your-project-123.convex.cloud
PUBLIC_CONVEX_SITE_URL=https://your-project-123.convex.site
SITE_URL=http://localhost:5173
BETTER_AUTH_URL=http://localhost:5173

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_MAGIC_LINK_ENABLED=false

# Hosted demo controls. Disable entirely for production forks that do not need it.
DEMO_ENABLED=true

# Optional installable PWA metadata and service worker. Disabled by default to avoid stale
# authenticated pages and large precaches; enable only after defining the product's cache policy.
ENABLE_PWA=false

# Google OAuth for Better Auth
# Google Cloud Console -> APIs & Services -> Credentials -> Create OAuth client ID.
# Application type: Web application.
# Authorized JavaScript origins:
# - http://localhost:5173
# - https://productplate.pages.dev
# Authorized redirect URIs:
# - http://localhost:5173/api/auth/callback/google
# - https://productplate.pages.dev/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email delivery for password reset and email-change approval.
RESEND_API_KEY=
RESET_EMAIL_FROM="Product Plate <no-reply@example.com>"
RESET_EMAIL_REPLY_TO=
TRANSACTIONAL_EMAIL_FROM="Product Plate <no-reply@example.com>"

# Public waitlist security and operator export.
# Generate each with: openssl rand -base64 32
WAITLIST_FINGERPRINT_SECRET=
WAITLIST_EXPORT_SECRET=

# AI SDK via OpenRouter's OpenAI-compatible API.
# The app uses the OpenRouter Free Models Router model id: openrouter/free.
OPENROUTER_API_KEY=
CHAT_MODEL=openrouter/free

# Request logging. Keep off locally unless debugging noisy server behavior.
OBSERVABILITY_LOG_REQUESTS=false

# Founder support fallback.
SUPPORT_EMAIL=

# Optional telemetry. Analytics does not load until consent is granted.
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
PUBLIC_SENTRY_DSN=

# Autumn Billing
AUTUMN_SECRET_KEY=

# Convex server environment. Also set this with `bun convex env set` when needed.
CONVEX_SITE_URL=https://your-project-123.convex.site

# Inactive kickstart options. Fill only if START_HERE.md selects that stack.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PUBLIC_STRIPE_PRICE_PRO=
POLAR_ACCESS_TOKEN=
POLAR_SERVER=sandbox
POLAR_PRODUCT_PRO=
CREEM_API_KEY=
CREEM_TEST_MODE=true
CREEM_PRODUCT_PRO=
CREEM_WEBHOOK_SECRET=
DATABASE_URL=
